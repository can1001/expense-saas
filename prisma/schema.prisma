// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 지출결의서 메인 테이블
model Expense {
  id                String               @id @default(cuid())

  // 작성자
  userId            String
  user              User                 @relation(fields: [userId], references: [id])

  // 기본 정보
  committee         String               // 위원회
  department        String               // 사역팀(부)
  budgetCategory    String               // 예산(항)
  budgetSubcategory String               // 예산(목)

  // 지출일자 (재정팀 입력)
  expenseDate       DateTime?

  // 청구금액 (자동 계산)
  requestAmount     Int

  // 세부 항목들
  items             ExpenseItem[]

  // 첨부파일들
  attachments       ExpenseAttachment[] @relation("ExpenseAttachments")

  // 신청 정보
  requestDate       DateTime             // 청구 일자
  requestTeam       String               @default("출납팀")
  applicantName     String               // 청구인
  applicantTitle    String?              // 직책

  // 은행 정보
  bankName          String               // 은행명
  accountNumber     String               // 계좌번호
  accountHolder     String               // 예금주

  // 결재 상태
  status            ApprovalStatus       @default(DRAFT)
  submittedAt       DateTime?            // 제출 일시
  approvedAt        DateTime?            // 최종 승인 일시
  rejectedAt        DateTime?            // 반려 일시

  // 지출 상태 (최종 승인 후 관리)
  paymentStatus     PaymentStatus        @default(PENDING)
  paymentCompletedAt DateTime?           // 지출완료 시각
  paymentCompletedBy String?             // 지출완료 처리자
  paymentNote       String?              // 지출 메모

  // 결재선 (1:1 관계)
  approvalLine      ApprovalLine?

  // 메타
  version           String               @default("4.1.3")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([userId])
  @@index([committee])
  @@index([department])
  @@index([budgetCategory, budgetSubcategory])
  @@index([requestDate])
  @@index([createdAt])
  @@index([status])
  @@index([applicantName])
  @@index([paymentStatus])
}

// 지출 세부 항목
model ExpenseItem {
  id           String   @id @default(cuid())
  expenseId    String
  expense      Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  
  budgetDetail String   // 예산(세목)
  description  String   // 적요 (상세 설명)
  unitPrice    Int      // 단가
  quantity     Int      // 인원(수량)
  amount       Int      // 금액 = TRUNC(unitPrice × quantity / 10) * 10
  
  order        Int      // 순서 (1~10)
  createdAt    DateTime @default(now())
  
  @@index([expenseId])
}

// 첨부파일 (영수증 이미지 등)
model ExpenseAttachment {
  id          String   @id @default(cuid())
  expenseId   String
  expense     Expense  @relation("ExpenseAttachments", fields: [expenseId], references: [id], onDelete: Cascade)

  // Cloudinary 정보
  publicId    String   // Cloudinary public_id
  url         String   // 이미지 URL
  secureUrl   String   // HTTPS URL
  format      String   // 파일 포맷 (jpg, png 등)

  // 파일 정보
  fileName    String   // 원본 파일명
  fileSize    Int      // 파일 크기 (bytes)
  width       Int?     // 이미지 너비
  height      Int?     // 이미지 높이

  // 메타
  createdAt   DateTime @default(now())

  @@index([expenseId])
}

// 예산 마스터 데이터 (드롭다운 옵션) - 레거시, 마이그레이션 후 제거 예정
model BudgetMaster {
  id           String   @id @default(cuid())

  // 계층 구조
  committee    String   // 위원회
  department   String   // 사역팀(부)
  category     String   // 예산(항)
  subcategory  String   // 예산(목)
  detail       String   // 예산(세목)

  // 추가 정보
  manager      String?  // 승인권자
  accountCode  String?  // 계정코드
  description  String?  // 항목 내역

  // 활성 상태
  isActive     Boolean  @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([committee, department, category, subcategory, detail])
  @@index([category, subcategory, detail])
  @@index([committee])
  @@index([department])
}

// ========================================
// 정규화된 예산 구조 (Normalized Budget Structure)
// ========================================

// 위원회
model Committee {
  id          String       @id @default(cuid())
  name        String       @unique  // "기획위원회", "선교위원회"
  sortOrder   Int          @default(0)
  isActive    Boolean      @default(true)

  // 위원장 (기본값, 실제 역할은 UserYearRole로 관리)
  leaderId    String?
  leader      User?        @relation("CommitteeLeader", fields: [leaderId], references: [id])

  departments Department[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([sortOrder])
  @@index([isActive])
  @@index([leaderId])
}

// 사역팀(부)
model Department {
  id           String     @id @default(cuid())
  committeeId  String
  committee    Committee  @relation(fields: [committeeId], references: [id])

  name         String     // "재정팀", "공간사역팀"
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)

  // 팀장 (기본값, 실제 역할은 UserYearRole로 관리)
  leaderId     String?
  leader       User?      @relation("DepartmentLeader", fields: [leaderId], references: [id])

  // 관계
  budgetDetails DepartmentBudgetDetail[]

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([committeeId, name])
  @@index([committeeId])
  @@index([sortOrder])
  @@index([isActive])
  @@index([leaderId])
}

// 예산(항)
model BudgetCategory {
  id            String              @id @default(cuid())
  name          String              @unique  // "사무행정비", "비전사역비"
  sortOrder     Int                 @default(0)
  isActive      Boolean             @default(true)

  subcategories BudgetSubcategory[]

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([sortOrder])
  @@index([isActive])
}

// 예산(목)
model BudgetSubcategory {
  id          String          @id @default(cuid())
  categoryId  String
  category    BudgetCategory  @relation(fields: [categoryId], references: [id])

  name        String          // "회의및접대비", "공간사역비"
  sortOrder   Int             @default(0)
  isActive    Boolean         @default(true)

  details     BudgetDetail[]

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([categoryId, name])
  @@index([categoryId])
  @@index([sortOrder])
  @@index([isActive])
}

// 예산(세목)
model BudgetDetail {
  id             String            @id @default(cuid())
  subcategoryId  String
  subcategory    BudgetSubcategory @relation(fields: [subcategoryId], references: [id])

  name           String            // "아웃팅비_재정팀", "인건비"
  accountCode    String?           // 계정코드
  description    String?           // 항목 내역
  sortOrder      Int               @default(0)
  isActive       Boolean           @default(true)

  // 관계
  yearSettings       BudgetDetailYear[]
  departmentDetails  DepartmentBudgetDetail[]

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([subcategoryId, name])
  @@index([subcategoryId])
  @@index([sortOrder])
  @@index([isActive])
}

// 연도별 세목 설정 (담당자 + 예산금액)
model BudgetDetailYear {
  id              String       @id @default(cuid())

  budgetDetailId  String
  budgetDetail    BudgetDetail @relation(fields: [budgetDetailId], references: [id], onDelete: Cascade)

  year            Int          // 2024, 2025, 2026...

  // 담당자 (1차 결재자) - User 테이블 참조
  managerId       String?
  manager         User?        @relation("BudgetDetailManager", fields: [managerId], references: [id])

  // 예산금액
  budgetAmount    Int          @default(0)   // 배정 예산
  usedAmount      Int          @default(0)   // 사용 금액 (집계)

  isActive        Boolean      @default(true)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([budgetDetailId, year])
  @@index([year])
  @@index([managerId])
  @@index([isActive])
}

// 사역팀별 사용 가능 세목 (부서-세목 연결)
model DepartmentBudgetDetail {
  id              String       @id @default(cuid())

  departmentId    String
  department      Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  budgetDetailId  String
  budgetDetail    BudgetDetail @relation(fields: [budgetDetailId], references: [id], onDelete: Cascade)

  isActive        Boolean      @default(true)

  createdAt       DateTime     @default(now())

  @@unique([departmentId, budgetDetailId])
  @@index([departmentId])
  @@index([budgetDetailId])
}

// 저장된 은행 계좌 (사용자별)
model SavedBankAccount {
  id             String   @id @default(cuid())

  // 소유자
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 은행 정보
  bankName       String   // 은행명
  accountNumber  String   // 계좌번호
  accountHolder  String   // 예금주

  // 표시 이름 (드롭다운에서 구분용)
  nickname       String?  // 예: "개인 급여계좌", "사역팀 공용계좌"

  // 기본 계좌 여부
  isDefault      Boolean  @default(false)

  // 메타
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // 같은 사용자 내에서만 계좌번호 중복 방지
  @@unique([userId, accountNumber])
  @@index([userId])
  @@index([isDefault])
  @@index([createdAt])
}

// 간편 지출결의서 (Ver.4.1.4) - 항목별 예산 선택
model SimpleExpense {
  id              String   @id @default(cuid())

  // 지출일자
  expenseDate     DateTime?

  // 청구금액 (자동 계산)
  requestAmount   Int

  // 세부 항목들
  items           SimpleExpenseItem[]

  // 첨부파일들
  attachments     SimpleExpenseAttachment[]

  // 청구 정보
  requestDate     DateTime   // 청구 일자
  applicantName   String     // 청구인 (1명)

  // 은행 정보
  bankName        String     // 은행명
  accountNumber   String     // 계좌번호
  accountHolder   String     // 예금주

  // 메타
  version         String   @default("4.1.4")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([requestDate])
  @@index([createdAt])
}

// 간편 지출결의서 세부 항목
model SimpleExpenseItem {
  id              String        @id @default(cuid())
  expenseId       String
  expense         SimpleExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  // 예산 항목 (각 행마다 선택)
  budgetCategory     String    // 예산(항)
  budgetSubcategory  String    // 예산(목)
  budgetDetail       String    // 예산(세목)

  // 적요
  description     String       // 적요 (상세 설명)

  // 금액 (자동 계산)
  unitPrice       Int          // 단가
  quantity        Int          // 인원(수량)
  amount          Int          // 금액 = TRUNC(unitPrice × quantity / 10) * 10

  order           Int          // 순서 (1~10)
  createdAt       DateTime     @default(now())

  @@index([expenseId])
}

// 간편 지출결의서 첨부파일
model SimpleExpenseAttachment {
  id          String        @id @default(cuid())
  expenseId   String
  expense     SimpleExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  // Cloudinary 정보
  publicId    String   // Cloudinary public_id
  url         String   // 이미지 URL
  secureUrl   String   // HTTPS URL
  format      String   // 파일 포맷 (jpg, png 등)

  // 파일 정보
  fileName    String   // 원본 파일명
  fileSize    Int      // 파일 크기 (bytes)
  width       Int?     // 이미지 너비
  height      Int?     // 이미지 높이

  // 메타
  createdAt   DateTime @default(now())

  @@index([expenseId])
}

// ========================================
// 결재 시스템 (Approval System)
// ========================================

// 결재 상태 (3단계 결재: 팀장 → 회계 → 재정팀장)
enum ApprovalStatus {
  DRAFT             // 작성중 (제출 전)
  PENDING           // 결재 대기 (제출됨, 1차 팀장 결재 대기)
  APPROVED_STEP_1   // 1차 승인 완료 (팀장 승인, 2차 회계 결재 대기)
  APPROVED_STEP_2   // 2차 승인 완료 (회계 승인, 3차 재정팀장 결재 대기)
  APPROVED_FINAL    // 최종 승인 (재정팀장 승인 완료)
  REJECTED          // 반려
  WITHDRAWN         // 회수 (작성자가 철회)
}

// 지출 상태 (최종 승인 후 관리)
enum PaymentStatus {
  PENDING     // 지출예정 (기본값)
  COMPLETED   // 지출완료
}

// 결재선 (지출결의서당 1개, 스냅샷)
model ApprovalLine {
  id          String   @id @default(cuid())
  expenseId   String   @unique
  expense     Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  // 결재 단계들
  steps       ApprovalStep[]

  // 결재선 스냅샷 (제출 시점 고정)
  snapshot    Json?    // 제출 시 결재선 전체를 JSON으로 저장

  // 현재 진행 상태
  currentStep Int      @default(1)  // 현재 결재 단계 (1부터 시작)
  totalSteps  Int                   // 전체 결재 단계 수

  // 긴급 처리 플래그
  isUrgent    Boolean  @default(false)

  // 메타
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([expenseId])
  @@index([currentStep])
}

// 결재 단계 (결재선당 여러 개)
model ApprovalStep {
  id              String         @id @default(cuid())
  approvalLineId  String
  approvalLine    ApprovalLine   @relation(fields: [approvalLineId], references: [id], onDelete: Cascade)

  // 단계 정보
  stepNumber      Int            // 결재 순서 (1, 2, 3...)
  stepName        String         // 결재자 역할명 (예: "팀장", "회계", "재정팀장")

  // 결재자 정보
  approverName    String         // 결재자 이름
  approverEmail   String?        // 결재자 이메일 (선택)
  approverTitle   String?        // 결재자 직책

  // 대리 결재
  delegatedTo     String?        // 대리 결재자 이름
  delegationReason String?       // 대리 사유

  // 결재 상태
  status          StepStatus     @default(PENDING)
  approvedAt      DateTime?      // 승인 일시
  rejectedAt      DateTime?      // 반려 일시
  comment         String?        // 결재 의견

  // 필수 여부
  isRequired      Boolean        @default(true)  // 필수 결재자 여부
  isParallel      Boolean        @default(false) // 병렬 승인 여부 (동일 stepNumber)

  // 메타
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([approvalLineId])
  @@index([stepNumber])
  @@index([approverName])
  @@index([status])
}

// 결재 단계 상태
enum StepStatus {
  PENDING     // 대기중
  APPROVED    // 승인
  REJECTED    // 반려
  SKIPPED     // 건너뜀 (선택적 결재자)
}

// 결재 액션 타입
enum ApprovalAction {
  SUBMIT           // 제출
  APPROVE          // 승인
  REJECT           // 반려
  RESUBMIT         // 재제출
  WITHDRAW         // 회수
  MODIFY_LINE      // 결재선 수정
  DELEGATE         // 위임/대리 지정
  PAYMENT_COMPLETE // 지출완료 처리
  PAYMENT_REVERT   // 지출예정으로 되돌림
}

// ========================================
// 사용자 관리 (User Management)
// ========================================

// 사용자 역할 (레거시 - 마이그레이션 후 제거 예정)
enum UserRole {
  admin            // 시스템 관리자
  finance_head     // 재정팀장 (3차/최종 결재)
  accountant       // 회계 (2차 결재)
  team_leader      // 팀장 (1차 결재)
  admin_assistant  // 행정간사 (지출관리, 엑셀 다운로드)
  user             // 일반 사용자
}

// 역할 마스터 테이블
model Role {
  id           String   @id @default(cuid())
  code         String   @unique    // admin, finance_head, accountant, team_leader, admin_assistant, user
  name         String              // 관리자, 재정팀장, 회계, 팀장, 행정간사, 사용자
  description  String?             // 역할 설명
  stepNumber   Int?                // 결재 단계 (1, 2, 3, null)
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)

  // 권한 플래그
  canApprove       Boolean @default(false)  // 결재 권한
  canManageExpense Boolean @default(false)  // 지출 관리 권한
  canAccessAdmin   Boolean @default(false)  // 관리자 메뉴 접근
  canExportData    Boolean @default(false)  // 데이터 내보내기 권한

  // 관계
  users         User[]          @relation("UserRole")
  userYearRoles UserYearRole[]  @relation("YearRole")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([code])
  @@index([stepNumber])
  @@index([isActive])
}

// 사용자 테이블
model User {
  id          String    @id @default(cuid())
  userid      String    @unique           // 로그인 아이디 (예: 청연정혜종)
  username    String                      // 표시 이름 (예: 정혜종)
  password    String?                     // 해시된 비밀번호 (향후 인증용)
  role        UserRole  @default(user)    // 기본 역할 (레거시, 마이그레이션 후 제거)
  roleId      String?                     // 새 역할 테이블 참조
  roleRef     Role?     @relation("UserRole", fields: [roleId], references: [id])
  department  String?                     // 소속 부서 (참고용)
  isActive    Boolean   @default(true)    // 활성 상태

  // 관계
  yearRoles          UserYearRole[]
  bankAccounts       SavedBankAccount[]         // 저장된 은행 계좌들
  expenses           Expense[]                  // 작성한 지출결의서들
  managedBudgets     BudgetDetailYear[]  @relation("BudgetDetailManager")  // 담당 예산 세목들

  // 리더 역할 (기본값 설정용)
  ledCommittees      Committee[]   @relation("CommitteeLeader")   // 담당 위원회
  ledDepartments     Department[]  @relation("DepartmentLeader")  // 담당 사역팀

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([role])
  @@index([roleId])
  @@index([department])
  @@index([isActive])
}

// 연도별 사용자 역할 (finance_head, accountant, team_leader, admin_assistant)
model UserYearRole {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  year        Int                         // 연도 (예: 2024, 2025)
  role        UserRole                    // 해당 연도의 역할 (레거시, 마이그레이션 후 제거)
  roleId      String?                     // 새 역할 테이블 참조
  roleRef     Role?     @relation("YearRole", fields: [roleId], references: [id])
  department  String?                     // 소속 부서 (팀장인 경우)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, year])                // 사용자당 연도별 1개의 역할만 가능
  @@index([year])
  @@index([role])
  @@index([roleId])
  @@index([userId])
}

// ========================================
// 변경 이력 추적 (Change History)
// ========================================

// 사용자 연도별 역할 변경 이력
model UserYearRoleHistory {
  id              String    @id @default(cuid())

  userYearRoleId  String?   // 삭제된 경우 null일 수 있음
  userId          String    // 대상 사용자
  year            Int       // 적용 연도

  // 변경 정보
  action          String    // CREATE, UPDATE, DELETE
  changedBy       String    // 변경 수행자 이름
  changedById     String?   // 변경 수행자 ID

  // 변경 전 값
  previousRole    String?   // 이전 역할
  previousDept    String?   // 이전 소속 부서

  // 변경 후 값
  newRole         String?   // 새 역할
  newDept         String?   // 새 소속 부서

  // 메타
  changedAt       DateTime  @default(now())

  @@index([userId])
  @@index([year])
  @@index([changedAt])
  @@index([action])
}

// 예산 세목 연도별 설정 변경 이력
model BudgetDetailYearHistory {
  id                  String    @id @default(cuid())

  budgetDetailYearId  String?   // 삭제된 경우 null일 수 있음
  budgetDetailId      String    // 대상 세목
  budgetDetailName    String?   // 세목명 (조회 편의용)
  year                Int       // 적용 연도

  // 변경 정보
  action              String    // CREATE, UPDATE, DELETE
  changedBy           String    // 변경 수행자 이름
  changedById         String?   // 변경 수행자 ID

  // 변경 전 값
  previousManagerId   String?   // 이전 담당자 ID
  previousManagerName String?   // 이전 담당자 이름
  previousBudgetAmt   Int?      // 이전 예산금액

  // 변경 후 값
  newManagerId        String?   // 새 담당자 ID
  newManagerName      String?   // 새 담당자 이름
  newBudgetAmt        Int?      // 새 예산금액

  // 메타
  changedAt           DateTime  @default(now())

  @@index([budgetDetailId])
  @@index([year])
  @@index([changedAt])
  @@index([action])
}

// 감사 로그 (모든 결재 액션 기록)
model ApprovalLog {
  id              String          @id @default(cuid())
  expenseId       String

  // 액션 정보
  action          ApprovalAction  // 액션 타입
  actorName       String          // 액션 수행자 이름
  actorEmail      String?         // 액션 수행자 이메일
  actorRole       String?         // 액션 수행자 역할

  // 결재 단계 정보 (승인/반려인 경우)
  stepNumber      Int?            // 몇 차 결재인지
  stepName        String?         // 결재자 역할명

  // 상태 변화
  previousStatus  String?         // 변경 전 상태
  newStatus       String          // 변경 후 상태

  // 상세 정보
  comment         String?         // 의견/사유
  metadata        Json?           // 추가 메타데이터 (IP, User Agent 등)

  // 스냅샷 (결재선 수정인 경우)
  beforeSnapshot  Json?           // 변경 전 결재선 스냅샷
  afterSnapshot   Json?           // 변경 후 결재선 스냅샷

  // 메타
  createdAt       DateTime        @default(now())

  @@index([expenseId])
  @@index([action])
  @@index([actorName])
  @@index([createdAt])
}
