# ─────────────────────────────────────────────────────────────
# Expense SaaS 백엔드 환경변수 예시
# RUNNING_ZONE 에 따라 .env.local / .env.prod 가 로드된다 (settings.py)
# ─────────────────────────────────────────────────────────────

# 실행 존: local | prod  (필수 — 미설정 시 부팅 거부, db/guard.py)
RUNNING_ZONE=local

# 데이터베이스 URL
#   local : sqlite+aiosqlite:///./dev.db
#   prod  : postgresql+asyncpg://<user>:<pw>@<host>:5432/<db>?sslmode=require
# 비워두면 settings 의 zone 조건부 기본값이 사용된다.
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# JWT
# ⚠️ 상호호환: SECRET_KEY 는 Next.js 프론트의 USER_JWT_SECRET 과 동일해야
#    FastAPI/Next.js 가 서로의 토큰을 검증할 수 있다 (로그인 커토버 전제).
#    로컬 크로스 로그인: 양쪽을 같은 값(예: user-secret-key-change-in-production)으로.
SECRET_KEY=change-me-in-prod
JWT_ISSUER=expense-saas
JWT_AUDIENCE=tenant-user
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 플랫폼(SuperAdmin) JWT — 일반 사용자 세션과 분리된 별도 시크릿 (별도 세션 체계, P1).
#   프로덕션 상호호환: Next.js 프론트의 SUPER_ADMIN_JWT_SECRET 과 동일해야 한다.
SUPER_ADMIN_JWT_SECRET=change-me-in-prod

# CORS (프론트 오리진, JSON 배열 형태)
CORS_ORIGINS=["http://localhost:3000"]
