{
  "name": "expense-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build --webpack",
    "start": "next start -p $PORT",
    "postinstall": "prisma generate",
    "lint": "eslint",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate dev",
    "db:backfill:roles": "ts-node --project tsconfig.scripts.json prisma/scripts/backfill-role-permissions.ts",
    "deploy:migrate": "prisma db push --accept-data-loss && pnpm run db:backfill:roles",
    "db:seed": "ts-node --project tsconfig.scripts.json prisma/seeds/budget-seed.ts",
    "db:seed:users": "ts-node --project tsconfig.scripts.json prisma/seeds/users-seed.ts",
    "db:seed:super-admin": "ts-node --project tsconfig.scripts.json prisma/seeds/super-admin-seed.ts",
    "db:seed:tenants": "ts-node --project tsconfig.scripts.json prisma/seeds/tenant-seed.ts",
    "db:seed:template:company": "ts-node --project tsconfig.scripts.json prisma/seeds/company-template-seed.ts",
    "db:seed:template:church": "ts-node --project tsconfig.scripts.json prisma/seeds/church-template-seed.ts",
    "db:seed:e2e": "ts-node --project tsconfig.scripts.json prisma/seeds/e2e-seed.ts",
    "bulk-upload": "ts-node --project tsconfig.scripts.json scripts/bulk-upload.ts",
    "generate-template": "ts-node --project tsconfig.scripts.json scripts/generate-upload-template.ts",
    "generate-users-template": "ts-node --project tsconfig.scripts.json scripts/generate-users-template.ts",
    "screenshots": "ts-node --project tsconfig.scripts.json scripts/screenshots/index.ts",
    "screenshots:expense": "ts-node --project tsconfig.scripts.json scripts/screenshots/index.ts expense",
    "screenshots:pwa": "ts-node --project tsconfig.scripts.json scripts/screenshots/index.ts pwa",
    "screenshots:push": "ts-node --project tsconfig.scripts.json scripts/screenshots/index.ts push",
    "screenshots:headed": "ts-node --project tsconfig.scripts.json scripts/screenshots/index.ts --headed",
    "screenshots:mobile": "ts-node --project tsconfig.scripts.json scripts/screenshots/index.ts --mobile",
    "test:push": "ts-node --project tsconfig.scripts.json scripts/test-push-notification.ts",
    "test:push:browser": "playwright test scripts/test-push-browser.ts --headed",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "dependencies": {
    "@capacitor/push-notifications": "^8.1.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-pdf/renderer": "^4.3.1",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.8.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dexie": "^4.3.0",
    "exceljs": "^4.4.0",
    "firebase-admin": "^14.1.0",
    "jose": "^6.2.3",
    "lucide-react": "^0.561.0",
    "next": "^16.1.6",
    "next-cloudinary": "^6.17.5",
    "pg": "^8.16.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.68.0",
    "react-swipeable": "^7.0.2",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.4.0",
    "uuid": "^14.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.1.13"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@firebase/util",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "serialize-javascript": "^7.0.5",
      "exceljs>uuid": "^14.0.0"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.15.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-dropzone": "^4.2.2",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.15",
    "@vitest/ui": "^4.0.15",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.5",
    "jsdom": "^27.2.0",
    "pptxgenjs": "^4.0.1",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vitest": "^4.0.15"
  }
}
