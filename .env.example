# ============================================
# 환경 설정 템플릿
# 이 파일을 복사하여 .env.local 파일을 생성하세요
# cp .env.example .env.local
# ============================================

# 환경 구분: development | test | production
NODE_ENV=development

# ============================================
# 보안 설정 (Security)
# ============================================

# 세션 암호화 키 (프로덕션 필수)
# 생성 방법: openssl rand -base64 32
# 중요: 프로덕션에서 반드시 설정해야 합니다!
SESSION_SECRET=""

# Rate Limiting Redis (멀티 인스턴스 환경용, 선택)
# 단일 인스턴스: 설정 불필요 (in-memory 사용)
# 멀티 인스턴스: Upstash Redis 또는 Redis 연결 URL 설정
# REDIS_URL="redis://..."

# ============================================
# 데이터베이스 (Database)
# ============================================

# 데이터베이스 연결 URL
# Development: 로컬 또는 개발용 DB
# Production: Neon 프로덕션 DB
DATABASE_URL="postgresql://username:password@host:5432/database?sslmode=require"

# 애플리케이션 URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cloudinary (이미지 업로드)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ============================================
# 웹 푸시 알림 (Web Push API / VAPID)
# ============================================

# VAPID 키 생성: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@example.com"

# ============================================
# FCM 푸시 알림 (Capacitor 모바일 앱용)
# ============================================

# Firebase 서비스 계정 JSON (한 줄 문자열로 stringify)
# 1. Firebase Console (https://console.firebase.google.com) → 프로젝트 생성
# 2. 프로젝트 설정 → 서비스 계정 → "새 비공개 키 생성" → JSON 다운로드
# 3. JSON을 한 줄로 minify 한 뒤 전체를 따옴표로 감싸 아래에 붙여넣기
# 4. 미설정 시 fcmProvider.isEnabled() = false 로 자동 비활성 (안전)
FIREBASE_SERVICE_ACCOUNT_JSON=""

# ============================================
# 알림 시스템 (NHN Notification Hub)
# ============================================

# 알림 활성화 (true | false)
NOTIFICATION_ENABLED="true"

# NHN Notification Hub (통합 API)
# https://www.nhncloud.com/ 가입 후 Notification Hub 서비스 활성화
NOTIFICATION_HUB_APP_KEY=""
NOTIFICATION_HUB_USER_ACCESS_KEY=""
NOTIFICATION_HUB_SECRET_ACCESS_KEY=""
NOTIFICATION_HUB_SMS_SENDER=""          # 사전 등록된 발신번호 (예: 01012345678)
NOTIFICATION_HUB_KAKAO_SENDER_KEY=""    # 카카오 발신 프로필 키 (선택)

# 카카오 알림톡 템플릿 코드 (심사 등록 필요)
KAKAO_TEMPLATE_SUBMIT=""
KAKAO_TEMPLATE_APPROVE=""
KAKAO_TEMPLATE_REJECT=""
KAKAO_TEMPLATE_WITHDRAW=""
KAKAO_TEMPLATE_PAYMENT_COMPLETE=""

# ============================================
# 자동이체 배치 (Recurring Expense Cron)
# ============================================

# 자동이체 일괄 처리 엔드포인트 보호용 시크릿 토큰
# 생성 방법: openssl rand -base64 32
# Render Cron Job과 웹 서비스 양쪽에 동일한 값으로 설정해야 함
# 미설정 시: 개발 환경에서는 경고 후 통과, 프로덕션에서는 차단
CRON_SECRET=""
